rlapping information -> good candidate for reduction')\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":460},"id":"gtF0g5asCA6f","executionInfo":{"status":"ok","timestamp":1781589881417,"user_tz":-330,"elapsed":921,"user":{"displayName":"MANTENA UMA SUSEELA","userId":"08502030394207373155"}},"outputId":"48c688fe-b20a-4098-c221-ab4dc113a1f1"},"execution_count":3,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 900x700 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["sensor pairs with |correlation| > 0.8: 74\n","=> many sensors carry overlapping information -> good candidate for reduction\n"]}]},{"cell_type":"code","source":["# 1. Counts\n","print(\"Number of machine readings:\", df[sensors].shape[0])\n","print(\"Number of sensors:\", df[sensors].shape[1])\n","\n","# 2. Most-correlated pair of sensors\n","\n","# Correlation matrix\n","corr = df[sensors].corr().abs()\n","\n","# Remove self-correlations\n","np.fill_diagonal(corr.values, 0)\n","\n","# Stack and sort\n","corr_pairs = corr.stack().sort_values(ascending=False)\n","\n","# Remove duplicate pairs (A,B) and (B,A)\n","seen = set()\n","for (s1, s2), value in corr_pairs.items():\n","    pair = tuple(sorted([s1, s2]))\n","    if pair not in seen:\n","        seen.add(pair)\n","        print(\"\\nMost-correlated pair:\")\n","        print(f\"{s1} and {s2}\")\n","        print(\"Absolute correlation =\", round(value, 4))\n","        break"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"itz7Gms7CTkg","executionInfo":{"status":"ok","timestamp":1781590056523,"user_tz":-330,"elapsed":17,"user":{"displayName":"MANTENA UMA SUSEELA","userId":"08502030394207373155"}},"outputId":"35d9ab8f-3dbd-4310-8ebe-9c4c621fb343"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Number of machine readings: 2000\n","Number of sensors: 24\n","\n","Most-correlated pair:\n","rpm and spindle_speed\n","Absolute correlation = 0.9511\n"]}]},{"cell_type":"code","source":["\n","# -----------------------------------------------------------\n","# 🔹 2A. LOW-VARIANCE FILTER (drop near-constant sensors)\n","# -----------------------------------------------------------\n","# Compare each sensor's coefficient of variation (std / mean): near-zero = barely changes.\n","cov = (df[sensors].std() / df[sensors].mean()).abs().sort_values()\n","print('Lowest variation (candidates to drop):')\n","print(cov.head(3).round(4))\n","near_constant = cov.head(2).index.tolist()\n","print('\\nDropping near-constant sensors:', near_constant)\n",""],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"2Wt_sujBC0rt","executionInfo":{"status":"ok","timestamp":1781590089911,"user_tz":-330,"elapsed":46,"user":{"displayName":"MANTENA UMA SUSEELA","userId":"08502030394207373155"}},"outputId":"b5eea575-f466-4318-8b49-b99d42112e65"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["Lowest variation (candidates to drop):\n","voltage         0.0007\n","humidity        0.0044\n","temp_ambient    0.0473\n","dtype: float64\n","\n","Dropping near-constant sensors: ['voltage', 'humidity']\n"]}]},{"cell_type":"code","source":["# 1. Drop near-constant sensors\n","reduced = df[sensors].drop(columns=near_constant)\n","\n","# 2. Find & drop one of each highly-correlated (> 0.9) pair\n","\n","# Absolute correlation matrix\n","corr_matrix = reduced.corr().abs()\n","\n","# Upper triangle only (avoid duplicate pairs)\n","upper = corr_matrix.where(\n","    np.triu(np.ones(corr_matrix.shape), k=1).astype(bool)\n",")\n","\n","# Columns to drop\n","to_drop = [\n","    column\n","    for column in upper.columns\n","    if any(upper[column] > 0.9)\n","]\n","\n","print(\"Highly correlated sensors to drop:\")\n","print(to_drop)\n","\n","# Drop them\n","reduced = reduced.drop(columns=to_drop)\n","\n","# 3. How many remain?\n","print(\"\\nSensors after filtering:\", reduced.shape[1])\n","\n","# Optional\n","print(\"Original sensors:\", len(sensors))\n","print(\"After removing near-constant + highly-correlated sensors:\",\n","      reduced.shape[1])\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"KUmNo9gMC-G1","executionInfo":{"status":"ok","timestamp":1781590174775,"user_tz":-330,"elapsed":9,"user":{"displayName":"MANTENA UMA SUSEELA","userId":"08502030394207373155"}},"outputId":"ddb245cd-3096-43f5-8327-ac3622020355"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["Highly correlated sensors to drop:\n","['temp_motor', 'temp_gearbox', 'oil_temp', 'vibration_y', 'vibration_z', 'acoustic_db', 'spindle_speed', 'feed_rate', 'torque', 'power_kw', 'current_a', 'current_b', 'current_c', 'load_pct']\n","\n","Sensors after filtering: 8\n","Original sensors: 24\n","After removing near-constant + highly-correlated sensors: 8\n"]}]},{"cell_type":"code","source":["from sklearn.feature_selection import mutual_info_classif\n","\n","mi = mutual_info_classif(df[sensors], df['condition'], random_state=0)\n","\n","mi = pd.Series(mi, index=sensors).sort_values(ascending=False)\n","\n","print('Top 8 sensors by mutual information with condition:')\n","print(mi.head(8).round(3))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ZsWcXSigDWNw","executionInfo":{"status":"ok","timestamp":1781590228556,"user_tz":-330,"elapsed":2056,"user":{"displayName":"MANTENA UMA SUSEELA","userId":"08502030394207373155"}},"outputId":"d2676049-ad25-48c9-f285-8b673facf797"},"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["Top 8 sensors by mutual information with condition:\n","temp_bearing    0.362\n","temp_gearbox    0.320\n","oil_temp        0.316\n","temp_motor      0.278\n","pressure_out    0.245\n","current_b       0.242\n","power_kw        0.236\n","pressure_in     0.236\n","dtype: float64\n"]}]},{"cell_type":"code","source":["# 1. Horizontal bar chart of top-10 MI scores\n","\n","top10 = mi.head(10).sort_values()   # sort for horizontal bar chart\n","\n","plt.figure(figsize=(8, 5))\n","top10.plot(kind='barh')\n","\n","plt.xlabel('Mutual Information')\n","plt.ylabel('Sensor')\n","plt.title('Top 10 Sensors by Mutual Information')\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":311},"id":"v8Y5l1-CD6dU","executionInfo":{"status":"ok","timestamp":1781590376367,"user_tz":-330,"elapsed":979,"user":{"displayName":"MANTENA UMA SUSEELA","userId":"08502030394207373155"}},"outputId":"c410fbf2-f4bd-4b7c-a6b9-7e75ccad8793"},"execution_count":10,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 800x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["\n","# -----------------------------------------------------------\n","# 🔹 4A. STANDARDISE (essential!) THEN FIT PCA\n","# -----------------------------------------------------------\n","from sklearn.preprocessing import StandardScaler\n","from sklearn.decomposition import PCA\n","\n","X = df[sensors].values\n","Xs = StandardScaler().fit_transform(X)      # PCA needs standardised inputs\n","pca = PCA().fit(Xs)\n","evr = pca.explained_variance_ratio_\n","print('Variance explained by the first 5 components:')\n","print((evr[:5] * 100).round(1))\n","print('First 5 components together:', round(evr[:5].sum() * 100, 1), '%')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"sMtNbommHvm2","executionInfo":{"status":"ok","timestamp":1781591378268,"user_tz":-330,"elapsed":51,"user":{"displayName":"MANTENA UMA SUSEELA","userId":"08502030394207373155"}},"outputId":"6ceb5fca-0879-4792-a4da-e94daaac5a88"},"execution_count":11,"outputs":[{"output_type":"stream","name":"stdout","text":["Variance explained by the first 5 components:\n","[67.8  6.4  5.4  4.2  4.1]\n","First 5 components together: 87.9 %\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 5A. CUMULATIVE EXPLAINED VARIANCE (the scree view)\n","# -----------------------------------------------------------\n","cum = np.cumsum(evr)\n","fig, ax = plt.subplots(figsize=(7, 4))\n","ax.plot(range(1, len(cum) + 1), cum * 100, marker='o', color='#3AAFA9')\n","ax.axhline(90, color='#F4B942', ls='--', label='90% threshold')\n","ax.set_xlabel('number of components'); ax.set_ylabel('cumulative variance (%)')\n","ax.set_title('Cumulative explained variance'); ax.legend()\n","plt.tight_layout(); plt.show()\n",""],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":285},"id":"45RklXaEHzwv","executionInfo":{"status":"ok","timestamp":1781591396568,"user_tz":-330,"elapsed":1119,"user":{"displayName":"MANTENA UMA SUSEELA","userId":"08502030394207373155"}},"outputId":"dbee71d8-9e26-4edd-9639-db50b672a828"},"execution_count":12,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 700x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["n_components_90 = np.argmax(cum >= 0.90) + 1\n","\n","print(\"Components needed for 90% variance:\", n_components_90)\n","\n","# 2. Report the compression\n","original_sensors = 24\n","print(f\"Compression: {original_sensors} sensors -> {n_components_90} principal components\")\n","\n","# Optional: percentage reduction\n","reduction = (1 - n_components_90 / original_sensors) * 100\n","print(f\"Dimensionality reduction: {reduction:.1f}%\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"K6GbHWTYH8KY","executionInfo":{"status":"ok","timestamp":1781591466882,"user_tz":-330,"elapsed":37,"user":{"displayName":"MANTENA UMA SUSEELA","userId":"08502030394207373155"}},"outputId":"924673d3-5730-4007-ddc9-9623cecc85de"},"execution_count":13,"outputs":[{"output_type":"stream","name":"stdout","text":["Components needed for 90% variance: 6\n","Compression: 24 sensors -> 6 principal components\n","Dimensionality reduction: 75.0%\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 6A. COMPRESS 24 SENSORS -> 2 COMPONENTS, THEN PLOT\n","# -----------------------------------------------------------\n","X2 = PCA(n_components=2).fit_transform(Xs)\n","colors = {'Normal': '#2D6A9F', 'Warning': '#F4B942', 'Failure': '#C0392B'}\n","fig, ax = plt.subplots(figsize=(7, 5))\n","for cond, col in colors.items():\n","    m = df['condition'] == cond\n","    ax.scatter(X2[m, 0], X2[m, 1], s=12, alpha=0.6, color=col, label=cond)\n","ax.set_xlabel('PC1'); ax.set_ylabel('PC2'); ax.legend(title='condition')\n","ax.set_title('24 sensors compressed to 2 PCA components')\n","plt.tight_layout(); plt.show()\n",""],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":354},"id":"PRHGZrTUILwC","executionInfo":{"status":"ok","timestamp":1781591493379,"user_tz":-330,"elapsed":629,"user":{"displayName":"MANTENA UMA SUSEELA","userId":"08502030394207373155"}},"outputId":"1c1e7f45-58e2-405e-ea39-13c2f3530c73"},"execution_count":14,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 700x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","execution_count":null,"metadata":{"id":"vzFIAG8fBN3P"},"outputs":[],"source":[]},{"cell_type":"code","source":["pc1_loadings = (\n","    pd.Series(pca.components_[0], index=sensors)\n","      .abs()\n","      .sort_values()\n","      .tail(3)\n",")\n","\n","print(\"Top 3 sensors contributing to PC1:\")\n","print(pc1_loadings)\n","\n","# Optional: show actual signed loadings\n","print(\"\\nActual PC1 loadings:\")\n","signed_loadings = pd.Series(pca.components_[0], index=sensors)\n","print(signed_loadings.loc[pc1_loadings.index])"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"sYUP0rPzIXJT","executionInfo":{"status":"ok","timestamp":1781591540329,"user_tz":-330,"elapsed":27,"user":{"displayName":"MANTENA UMA SUSEELA","userId":"08502030394207373155"}},"outputId":"b0de8119-7c11-4fa4-f80d-efd2e32edfc3"},"execution_count":15,"outputs":[{"output_type":"stream","name":"stdout","text":["Top 3 sensors contributing to PC1:\n","current_a    0.234046\n","current_c    0.234338\n","power_kw     0.236235\n","dtype: float64\n","\n","Actual PC1 loadings:\n","current_a    0.234046\n","current_c    0.234338\n","power_kw     0.236235\n","dtype: float64\n"]}]},{"cell_type":"code","source":["# -----------------------------------------------------------\n","# 🔹 7A. QUICK CHECK — classify condition with ALL 24 vs a few PCs\n","# -----------------------------------------------------------\n","from sklearn.model_selection import cross_val_score\n","from sklearn.linear_model import LogisticRegression\n","from sklearn.pipeline import make_pipeline\n","y = df['condition']\n","\n","full = make_pipeline(StandardScaler(), LogisticRegression(max_iter=1000))\n","pcap = make_pipeline(StandardScaler(), PCA(n_components=6), LogisticRegression(max_iter=1000))\n","s_full = cross_val_score(full, X, y, cv=5).mean()\n","s_pca = cross_val_score(pcap, X, y, cv=5).mean()\n","print(f'Accuracy with all 24 sensors : {s_full:.3f}')\n","print(f'Accuracy with 6 PCA components: {s_pca:.3f}')\n","print('=> a quarter of the dimensions keeps almost all the predictive power')\n",""],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"qeBl72kAIbiC","executionInfo":{"status":"ok","timestamp":1781591557982,"user_tz":-330,"elapsed":1078,"user":{"displayName":"MANTENA UMA SUSEELA","userId":"08502030394207373155"}},"outputId":"a6500b82-51a0-46c4-b25c-8344c6f1b693"},"execution_count":16,"outputs":[{"output_type":"stream","name":"stdout","text":["Accuracy with all 24 sensors : 0.748\n","Accuracy with 6 PCA components: 0.754\n","=> a quarter of the dimensions keeps almost all the predictive power\n"]}]},{"cell_type":"code","source":["from sklearn.decomposition import PCA\n","from sklearn.pipeline import Pipeline\n","from sklearn.model_selection import cross_val_score\n","from sklearn.linear_model import LogisticRegression\n","import pandas as pd\n","import numpy as np\n","\n","# Assume:\n","# Xs = standardized sensor data\n","# y = df['condition']\n","\n","results = []\n","\n","for n in [2, 4, 6, 8, 10]:\n","\n","    pipe = Pipeline([\n","        ('pca', PCA(n_components=n)),\n","        ('clf', LogisticRegression(max_iter=1000))\n","    ])\n","\n","    acc = cross_val_score(\n","        pipe,\n","        Xs,\n","        df['condition'],\n","        cv=5,\n","        scoring='accuracy'\n","    ).mean()\n","\n","    results.append([n, acc])\n","\n","# Results table\n","results_df = pd.DataFrame(\n","    results,\n","    columns=['n_components', 'cv_accuracy']\n",")\n","\n","print(results_df)\n","\n","# Optional: full-feature baseline (no PCA)\n","baseline_acc = cross_val_score(\n","    LogisticRegression(max_iter=1000),\n","    Xs,\n","    df['condition'],\n","    cv=5,\n","    scoring='accuracy'\n",").mean()\n","\n","print(\"\\nFull-feature accuracy:\", round(baseline_acc, 4))\n","\n","# Find the fewest components that match the baseline\n","# (within 0.01 = 1 percentage point)\n","matching = results_df[\n","    results_df['cv_accuracy'] >= baseline_acc - 0.01\n","]\n","\n","if len(matching) > 0:\n","    fewest_components = matching['n_components'].min()\n","    print(\"Fewest components matching full accuracy:\",\n","          fewest_components)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"7kMKy_bZIkH1","executionInfo":{"status":"ok","timestamp":1781591610737,"user_tz":-330,"elapsed":4206,"user":{"displayName":"MANTENA UMA SUSEELA","userId":"08502030394207373155"}},"outputId":"e8e68598-f0b0-4393-c86b-903a4114a919"},"execution_count":17,"outputs":[{"output_type":"stream","name":"stdout","text":["   n_components  cv_accuracy\n","0             2       0.7480\n","1             4       0.7420\n","2             6       0.7535\n","3             8       0.7480\n","4            10       0.7450\n","\n","Full-feature accuracy: 0.7485\n","Fewest components matching full accuracy: 2\n"]}]}]}